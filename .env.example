# Automaton - Configuration de l'environnement
# Stack d'automatisation de contenus IA générique.
# Copie ce fichier en .env et remplace les valeurs par les tiennes.

# === Infrastructure ===
DOMAIN=automaton.neurenova.tech
TIMEZONE=Europe/Paris

# === n8n ===
N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=change_me_n8n_db_password
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_n8n_password
N8N_ENCRYPTION_KEY=change_me_random_32_char_string
N8N_HOST=n8n.automaton.neurenova.tech
N8N_PROTOCOL=https

# === PostgreSQL ===
# Shared database. One schema per workflow (music_ai, workflow_template, etc.)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=automaton
POSTGRES_WORKFLOW_SCHEMAS=music_ai,workflow_template

# === APIs Tierces (activer selon les workflows) ===
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...
MISTRAL_API_KEY=...
SUNO_API_KEY=...
LEONARDO_API_KEY=...
YOUTUBE_API_KEY=...

# === Publication multi-plateforme (sécurité: dry_run par défaut) ===
# Active/désactive les plateformes sans toucher au code. Supportées: youtube, tiktok, meta
PUBLISH_PLATFORMS_ENABLED=youtube,tiktok,meta
# true = le endpoint /publish ne publie pas réellement, retourne un aperçu.
# Pour publier en vrai, envoyer dry_run=false dans l'appel OU mettre false ici.
PUBLISH_DRY_RUN=true
# YouTube OAuth (obligatoire pour vraie publication YouTube)
YOUTUBE_CLIENT_ID=...
YOUTUBE_CLIENT_SECRET=...
YOUTUBE_REFRESH_TOKEN=...
# TikTok / Meta (à compléter quand on branche les providers)
# TIKTOK_CLIENT_KEY=...
# TIKTOK_CLIENT_SECRET=...
# META_ACCESS_TOKEN=...

# === Génération d'images (multi-fournisseur) ===
# Fournisseur par défaut si l'appel ne précise pas 'provider'.
IMAGE_PROVIDER=leonardo
# Fournisseurs activés (active/désactive sans toucher au code). Supportés: leonardo, openai
IMAGE_PROVIDERS_ENABLED=leonardo,openai
# Overrides optionnels de modèle
OPENAI_IMAGE_MODEL=dall-e-3
# LEONARDO_MODEL_ID=6b645e2f-82f2-4b66-8f5e-c52983bda5e4
# UDIO_API_KEY=...

# === Voix (ElevenLabs) ===
ELEVENLABS_API_KEY=...
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# === Sous-titres (OpenAI Whisper) ===
# WHISPER_MODEL=whisper-1

# === Stockage (S3 ou compatible) ===
S3_BUCKET=automaton-production
S3_REGION=eu-central-1
S3_ACCESS_KEY=...
S3_SECRET_KEY=...

# === Stockage Cloudinary (alternative) ===
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# === Upload plateformes ===
TIKTOK_CLIENT_KEY=...
TIKTOK_CLIENT_SECRET=...
# Token court-terme à rafraîchir toutes les 24h (via n8n ou script dédié)
TIKTOK_ACCESS_TOKEN=...
META_ACCESS_TOKEN=...
INSTAGRAM_ACCOUNT_ID=...

# === Stock media (Pexels / Pixabay / Unsplash) ===
# Sources activées (séparées par virgule). Supportées: pexels, pixabay, unsplash
STOCK_PROVIDERS_ENABLED=pexels,pixabay,unsplash
PEXELS_API_KEY=...
PIXABAY_API_KEY=...
UNSPLASH_ACCESS_KEY=...

# === Fact-checking & SEO (provider LLM par défaut) ===
# Providers disponibles: bedrock, mistral, openai, anthropic, deepseek
FACT_CHECK_PROVIDER=bedrock
SEO_PROVIDER=bedrock

# === Script générique multi-profil ===
# Provider LLM par défaut si non précisé dans l'appel
SCRIPT_PROVIDER=bedrock
DEFAULT_SCRIPT_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

# === Analytics ===
YOUTUBE_CLIENT_ID=...
YOUTUBE_CLIENT_SECRET=...
YOUTUBE_REFRESH_TOKEN=...

# === Green API WhatsApp (2 instances) ===
# Instance 1: Music AI Agent (numero: 237657185475)
GREEN_API_1_INSTANCE_ID=7105...
GREEN_API_1_TOKEN=7e9c8...
GREEN_API_1_BASE_URL=https://api.green-api.com

# Instance 2: Personal Chatbot (numero: 237676377369)
GREEN_API_2_INSTANCE_ID=7105...
GREEN_API_2_TOKEN=7e9c8...
GREEN_API_2_BASE_URL=https://api.green-api.com

# === Music AI Agent Authorization (comma-separated list of phone numbers allowed to use the agent)
MUSIC_AI_AUTHORIZED_NUMBERS=237657185475

# === Chatbot Authorization (comma-separated list of phone numbers allowed to toggle bot on/off)
CHATBOT_AUTHORIZED_NUMBERS=237676377369,237657185475

# === Hermes Agent ===
HERMES_PROVIDER=nous
HERMES_MODEL=
HERMES_API_KEY=
HERMES_HCI_PASSWORD=change_me_hci_password

# === AWS Bedrock (Claude via Bedrock + Hermes) ===
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
# Modèle Bedrock par défaut (Claude Sonnet 3.5)
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# === Notifications ===
SLACK_WEBHOOK_URL=...
DISCORD_WEBHOOK_URL=...
