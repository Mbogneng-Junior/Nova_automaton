# Automaton - Configuration de l'environnement
# Stack d'automatisation de contenus IA générique.
# Copie ce fichier en .env et remplace les valeurs par les tiennes.

# === Infrastructure ===
DOMAIN=automaton.neurenova.tech
TIMEZONE=Europe/Paris

# === n8n ===
N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=change_me_n8n_db_password
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_n8n_password
N8N_ENCRYPTION_KEY=change_me_random_32_char_string
N8N_HOST=n8n.automaton.neurenova.tech
N8N_PROTOCOL=https

# === PostgreSQL ===
# Shared database. One schema per workflow (music_ai, workflow_template, etc.)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=automaton
POSTGRES_WORKFLOW_SCHEMAS=music_ai,workflow_template

# === APIs Tierces (activer selon les workflows) ===
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...
MISTRAL_API_KEY=...
SUNO_API_KEY=...
LEONARDO_API_KEY=...
YOUTUBE_API_KEY=...
# UDIO_API_KEY=...
# ELEVENLABS_API_KEY=...

# === Stockage (S3 ou compatible) ===
S3_BUCKET=automaton-production
S3_REGION=eu-central-1
S3_ACCESS_KEY=...
S3_SECRET_KEY=...

# === Stockage Cloudinary (alternative) ===
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# === Upload plateformes ===
TIKTOK_CLIENT_KEY=...
TIKTOK_CLIENT_SECRET=...
META_ACCESS_TOKEN=...
INSTAGRAM_ACCOUNT_ID=...

# === Analytics ===
YOUTUBE_CLIENT_ID=...
YOUTUBE_CLIENT_SECRET=...
YOUTUBE_REFRESH_TOKEN=...

# === Green API WhatsApp (2 instances) ===
# Instance 1: Music AI Agent (numero: 237657185475)
GREEN_API_1_INSTANCE_ID=7105...
GREEN_API_1_TOKEN=7e9c8...
GREEN_API_1_BASE_URL=https://api.green-api.com

# Instance 2: Personal Chatbot (numero: 237676377369)
GREEN_API_2_INSTANCE_ID=7105...
GREEN_API_2_TOKEN=7e9c8...
GREEN_API_2_BASE_URL=https://api.green-api.com

# === Music AI Agent Authorization (comma-separated list of phone numbers allowed to use the agent)
MUSIC_AI_AUTHORIZED_NUMBERS=237657185475

# === Chatbot Authorization (comma-separated list of phone numbers allowed to toggle bot on/off)
CHATBOT_AUTHORIZED_NUMBERS=237676377369,237657185475

# === Hermes Agent ===
HERMES_PROVIDER=nous
HERMES_MODEL=
HERMES_API_KEY=
HERMES_HCI_PASSWORD=change_me_hci_password

# === AWS Bedrock (Hermes) ===
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# === Notifications ===
SLACK_WEBHOOK_URL=...
DISCORD_WEBHOOK_URL=...
